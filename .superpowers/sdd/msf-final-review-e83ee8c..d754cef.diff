+      key: `${unitKeyPrefix}.0.raw44`,
+      offset: 0x44,
+      size: 2,
+      type: 'u16',
+      domain: 'units',
+      groupKey: 'units.0',
+      memberPath: `${memberPrefix}[0].raw_44`,
+    }),
+  )
+
+  return fields
