+function deriveGameCode(metadataName: string): GameCode {
+  if (metadataName.includes('FE6')) return 'FE6'
+  if (metadataName.includes('FE7')) return 'FE7'
+  if (metadataName.includes('FE8') || metadataName.includes('FE9')) return 'FE8'
