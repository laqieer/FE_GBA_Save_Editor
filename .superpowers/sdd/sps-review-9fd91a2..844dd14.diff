+    saveSlot: bytes[p + 0x0c],
+    chapterIndex: readI8(bytes, p + 0x0e),
+    chapterTurn: readU16(bytes, p + 0x10),
+    chapterStateBits: bytes[p + 0x14],
+    playthroughId: bytes[p + 0x18],
+    chapterMode: bytes[p + 0x1b],
